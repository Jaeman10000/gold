# 광맥(Gwangmaek) backend 환경변수 예시
# 실제 값은 .env 에 넣고, .env 는 절대 커밋하지 않는다 (CLAUDE.md 하드룰 §4).
# cp .env.example .env  후 채우기.

# --- 키움 REST API (Phase 2) ---
# openapi.kiwoom.com → 앱 등록 → 앱키·시크릿 발급
# 실전: https://api.kiwoom.com  /  모의투자: https://mockapi.kiwoom.com
KIWOOM_APP_KEY=
KIWOOM_APP_SECRET=
# KIWOOM_USE_MOCK=false   # true 로 설정하면 모의투자 서버(mockapi.kiwoom.com) 사용

# --- DB ---
DATABASE_URL=sqlite:///./data.db

# --- 데이터 소스 ---
# mock  : 모의 데이터 (Phase 1 기본값, 키움 연동 불필요)
# kiwoom: 실제 키움 API (Phase 2. 위 앱키·시크릿 필수)
DATA_PROVIDER=mock

# --- CORS (프론트 dev 서버) ---
CORS_ORIGINS=http://localhost:5173
