# 광맥(Gwangmaek) 백엔드 환경변수
# Railway → Variables 탭에 아래 키들을 직접 입력한다.
# 로컬 개발: cp .env.example .env 후 값 채우기. .env 는 절대 커밋 금지(§4).

# ── 키움 REST API ──────────────────────────────────────────────────────────────
# openapi.kiwoom.com → 앱 등록 → 앱키·시크릿 발급
KIWOOM_APP_KEY=
KIWOOM_APP_SECRET=
# KIWOOM_USE_MOCK=false  # true = 모의투자 서버(mockapi.kiwoom.com)

# ── DART OpenAPI (재무 데이터) ──────────────────────────────────────────────────
# opendart.fss.or.kr 가입 → API 키 발급 (무료). 없으면 재무(30%) N/A 처리.
DART_API_KEY=

# ── 데이터 소스 ────────────────────────────────────────────────────────────────
# mock  : 모의 데이터 (로컬 개발·테스트)
# kiwoom: 실제 키움 API
DATA_PROVIDER=kiwoom

# ── DB ─────────────────────────────────────────────────────────────────────────
# Railway Volume 마운트 후: sqlite:////data/gwangmaek.db  (슬래시 4개 = 절대경로)
# 로컬 개발:              sqlite:///./data.db
DATABASE_URL=sqlite:///./data.db

# ── CORS ───────────────────────────────────────────────────────────────────────
# 프론트 Railway URL 또는 Vercel URL (콤마 구분). 배포 후 채우기.
# 로컬: http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# ── 패스코드 접근 제한 (v1.5 싱글유저) ────────────────────────────────────────
# 비워두면 패스코드 없음 (로컬 개발 시 편의). 배포 시 4자리 이상 문자열 설정.
APP_PASSCODE=
